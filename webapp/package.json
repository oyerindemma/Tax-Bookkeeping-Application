{
  "name": "webapp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run prisma:generate:local && next dev",
    "build": "npm run prisma:generate && next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "npm run prisma:generate",
    "prisma:generate": "node prisma/scripts/generate-client.mjs",
    "prisma:generate:local": "prisma generate --schema prisma/schema.prisma",
    "prisma:generate:production": "prisma generate --schema prisma/postgres/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:db:push": "prisma db push --schema prisma/schema.prisma",
    "prisma:db:push:production": "prisma db push --schema prisma/postgres/schema.prisma",
    "vercel-build": "npm run build",
    "backfill:workspaces": "node prisma/scripts/backfill-workspaces.mjs",
    "seed:demo": "node prisma/scripts/seed-demo.mjs",
    "env:check": "node prisma/scripts/check-env.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "nodemailer": "^8.0.2",
    "pdf-parse": "^2.4.5",
    "prisma": "^6.19.2",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
